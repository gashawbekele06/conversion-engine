# Kill switch — DEFAULT UNSET routes all outbound to staff sink.
# Do NOT set this to 1 without program-staff review.
# TENACIOUS_LIVE=1

# LLM tier: dev | eval
LLM_TIER=dev
LLM_MODEL_DEV=qwen/qwen3-next-80b-a3b
LLM_MODEL_EVAL=anthropic/claude-sonnet-4.6

# OpenRouter (primary LLM gateway)
# OPENROUTER_API_KEY=

# Email providers (either is fine)
# RESEND_API_KEY=
# MAILERSEND_API_KEY=

# Africa's Talking (SMS sandbox)
# AT_USERNAME=sandbox
# AT_API_KEY=

# HubSpot Developer Sandbox (MCP)
# HUBSPOT_TOKEN=

# Cal.com self-hosted
# CALCOM_API_KEY=

# Langfuse
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Staff sinks (overrides defaults)
STAFF_SINK_EMAIL=challenge-sink@tenacious.internal
STAFF_SINK_SMS=+10000000000
